# 复制为 .env 并填写实际值：
#   cp .env.example .env
#
# 应用启动（import robot_agent）或调用 make_model 时会自动加载 .env。
# 已在 shell 中导出的变量优先，不会被 .env 覆盖。

# --- LLM 远程决策大脑 ---

# Provider: openai | openai_compatible | anthropic
LLM_PROVIDER=openai

# API 密钥（也可改用 OPENAI_API_KEY / ANTHROPIC_API_KEY）
LLM_API_KEY=

# OpenAI 官方服务留空；兼容端点填写服务的 base URL。
# Ollama 示例: http://localhost:11434/v1
LLM_BASE_URL=

# 模型名称（两档未单独指定时共用 LLM_MODEL）
LLM_MODEL=
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_SMART=gpt-4o
# 内置 VLM（describe_image）；留空依次回退 LLM_MODEL、LLM_MODEL_SMART、provider vision 默认值
LLM_MODEL_VISION=
